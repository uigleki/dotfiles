# 应用快捷键：
#
# win + enter => 打开终端
# win + e => 打开 emacs
# win + x => 打开电子书
# win + z => 打开浏览器
#
# 常用快捷键：
# alt + tab => 切换窗口
# win + 方向键 => 移动窗口
# ctrl + q => 关闭窗口
#
# 例外快捷键：
#
# ctrl + d => 退出终端
# ctrl + x 接 ctrl + c => 退出 emacs

[Alacritty.desktop]
New=none,none,New Terminal
_k_friendly_name=Alacritty
_launch=Meta+Return,none,Alacritty

[com.github.johnfactotum.Foliate.desktop]
_k_friendly_name=Foliate
_launch=Meta+X,none,Foliate
new-window=none,none,书库

[emacsclient.desktop]
_k_friendly_name=Emacs (Client)
_launch=none,none,Emacs (Client)
new-instance=none,none,New Instance
new-window=Meta+E,none,New Window

[firefox.desktop]
_k_friendly_name=Firefox
_launch=Meta+Z,none,Firefox
new-private-window=none,none,新建隐私浏览窗口
new-window=none,none,新建窗口

[org.flameshot.Flameshot.desktop]
Capture=Print,none,进行截图
Configure=none,none,配置
Launcher=none,none,打开启动器
_k_friendly_name=火焰截图
_launch=none,none,火焰截图
